---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ModelMiniCard from '../components/ModelMiniCard.astro';
import HomeCompareWidget from '../components/HomeCompareWidget.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE } from '../config/site.mjs';
import { formatDate } from '../lib/format';
import {
  CATEGORIES,
  topModelsForCategory,
  pricingPoles,
  formatPrice,
  MODELS_GENERATED_AT,
  MODELS,
} from '../lib/models';
import { faqJsonLd, itemListJsonLd } from '../lib/jsonld';

const reviews = (await getCollection('reviews', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publish_date - +a.data.publish_date)
  .slice(0, 6);
const blog = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publish_date - +a.data.publish_date)
  .slice(0, 4);

const poles = pricingPoles();

const faq = [
  {
    question: 'How often is the data updated?',
    answer: `Model metadata (pricing, context windows, modality, tool support) refreshes daily at 03:00 UTC via OpenRouter. Benchmark scores are hand-curated and updated when new evals land. Last refresh: ${new Date(MODELS_GENERATED_AT).toUTCString()}.`,
  },
  {
    question: 'Where do the benchmark scores come from?',
    answer:
      'Vendor model cards for first-party numbers, independent evaluators (Vellum, Artificial Analysis, etc.) when available. Every score on every model page links to its source. We never invent scores — missing benchmarks are shown as a dash, not a guess.',
  },
  {
    question: 'Why are some scores missing?',
    answer:
      'New models often lack independent benchmark coverage. We mark those as null rather than estimate. Use the leaderboard to filter by which benchmarks each model has been tested on.',
  },
  {
    question: 'Are these affiliate links?',
    answer: 'Where we have an affiliate relationship, the link is marked rel="sponsored" and disclosed on the disclosure page. Affiliate status never affects rating or category placement.',
  },
];

const homeJsonLd = [
  faqJsonLd(faq),
  itemListJsonLd({
    name: 'Top AI models by category',
    description: 'Top three models in each use-case category, ranked by our benchmark composite.',
    items: CATEGORIES.flatMap((c) =>
      topModelsForCategory(c.id).map((m) => ({ name: m.name, url: `/tools/${m.slug}` }))
    ),
  }),
];
---
<Layout
  title={SITE.name}
  description={`Compare ${MODELS.length}+ AI models with verified benchmarks and live pricing. Hands-on reviews and head-to-head comparisons of the best AI tools.`}
  breadcrumbs={[{ name: 'Home', href: '/' }]}
  jsonLd={homeJsonLd}
>
  {/* Hero */}
  <section class="border-b border-zinc-200 bg-gradient-to-b from-brand-50 to-white py-14 dark:border-zinc-800 dark:from-zinc-900 dark:to-zinc-950">
    <div class="container-wide">
      <p class="mb-3 text-sm font-medium text-brand-700 dark:text-brand-300">Live data · Updated {formatDate(MODELS_GENERATED_AT)}</p>
      <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-zinc-900 sm:text-5xl dark:text-zinc-100">
        Compare {MODELS.length}+ AI models with verified benchmarks and live pricing.
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-zinc-600 dark:text-zinc-400">
        Independent reviews. Hand-curated benchmark scores with sources. Pricing pulled daily from OpenRouter. No vendor marketing copy.
      </p>
      <form method="get" action="/search" class="mt-6 flex max-w-xl gap-2">
        <label for="q" class="sr-only">Search</label>
        <input id="q" name="q" type="search" placeholder="Search models, providers, benchmarks…" class="flex-1 rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 dark:border-zinc-700 dark:bg-zinc-900" />
        <button type="submit" class="btn-secondary">Search</button>
      </form>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/leaderboard" class="btn-primary">View full leaderboard</a>
        <a href="/tools" class="btn-secondary">All reviews</a>
      </div>
    </div>
  </section>

  {/* Top picks by use case — the centerpiece */}
  <section class="py-14">
    <div class="container-wide">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight">Top picks by use case</h2>
          <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">Ranked from {MODELS.length} models in our catalog.</p>
        </div>
        <a href="/leaderboard" class="text-sm font-medium text-brand-700 hover:underline dark:text-brand-300">All categories →</a>
      </div>

      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {CATEGORIES.map((c) => {
          const top = topModelsForCategory(c.id);
          return (
            <article class="card flex h-full flex-col p-5">
              <div class="flex items-start gap-3">
                <div class="text-2xl" aria-hidden="true">{c.emoji}</div>
                <div class="min-w-0 flex-1">
                  <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">{c.longLabel}</h3>
                  <p class="mt-1 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">{c.oneLiner}</p>
                </div>
              </div>
              <div class="mt-4 space-y-2">
                {top.length === 0 && (
                  <div class="rounded-md border border-dashed border-zinc-300 p-3 text-xs text-zinc-500 dark:border-zinc-700">No benchmarked picks yet — see the leaderboard.</div>
                )}
                {top.map((m, i) => <ModelMiniCard model={m} category={c} rank={i + 1} />)}
              </div>
              <a href={`/leaderboard?category=${c.id}`} class="mt-4 text-sm font-medium text-brand-700 hover:underline dark:text-brand-300">See all {c.label.toLowerCase()} models →</a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  {/* Pricing at a glance */}
  <section class="border-y border-zinc-200 bg-zinc-50 py-10 dark:border-zinc-800 dark:bg-zinc-900/40">
    <div class="container-wide">
      <h2 class="text-xl font-semibold">Pricing at a glance</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-3">
        {[
          { label: 'Cheapest frontier model', m: poles.cheapestFrontier },
          { label: 'Cheapest open-weight', m: poles.cheapestOpenWeight },
          { label: 'Most expensive in catalog', m: poles.mostExpensive },
        ].map((row) => row.m ? (
          <a href={`/tools/${row.m.slug}`} class="card flex items-center justify-between p-4 no-underline">
            <div>
              <div class="text-xs uppercase tracking-wide text-zinc-500">{row.label}</div>
              <div class="mt-1 text-sm font-semibold text-zinc-900 dark:text-zinc-100">{row.m.name}</div>
              <div class="text-xs text-zinc-500">{row.m.provider}</div>
            </div>
            <div class="text-right">
              <div class="text-sm font-semibold">{formatPrice(row.m.pricing.input_per_million)} / {formatPrice(row.m.pricing.output_per_million)}</div>
              <div class="text-xs text-zinc-500">in / out per 1M tokens</div>
            </div>
          </a>
        ) : null)}
      </div>
    </div>
  </section>

  {/* Side-by-side comparison widget */}
  <section class="py-12">
    <HomeCompareWidget />
  </section>

  {/* Latest reviews */}
  {reviews.length > 0 && (
    <section class="py-12">
      <div class="container-wide">
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold tracking-tight">Latest reviews</h2>
          <a href="/tools" class="text-sm font-medium text-brand-700 hover:underline dark:text-brand-300">All reviews →</a>
        </div>
        <ul class="mt-6 divide-y divide-zinc-200 dark:divide-zinc-800">
          {reviews.map((r) => (
            <li class="flex items-start justify-between gap-6 py-4">
              <div>
                <h3 class="font-semibold"><a href={`/tools/${r.data.tool_slug}`} class="no-underline hover:underline">{r.data.headline}</a></h3>
                <p class="mt-1 line-clamp-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">{r.data.intro}</p>
              </div>
              <time class="hidden shrink-0 text-sm text-zinc-500 sm:block" datetime={r.data.updated_date.toISOString()}>{formatDate(r.data.updated_date)}</time>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* Latest blog */}
  {blog.length > 0 && (
    <section class="border-t border-zinc-200 py-12 dark:border-zinc-800">
      <div class="container-wide">
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold tracking-tight">From the blog</h2>
          <a href="/blog" class="text-sm font-medium text-brand-700 hover:underline dark:text-brand-300">All posts →</a>
        </div>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {blog.map((p) => (
            <a href={`/blog/${p.slug}`} class="card block p-4 no-underline">
              <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">{p.data.title}</h3>
              <p class="mt-1 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">{p.data.description}</p>
              <p class="mt-2 text-xs text-zinc-500">{formatDate(p.data.publish_date)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Newsletter */}
  <section class="border-t border-zinc-200 py-12 dark:border-zinc-800">
    <div class="container-wide">
      <h2 class="text-2xl font-bold tracking-tight">Get the weekly recap</h2>
      <p class="mt-2 max-w-2xl text-zinc-600 dark:text-zinc-400">New benchmarks, pricing changes, and one model that surprised us each week. Free, no fluff.</p>
      <Newsletter />
    </div>
  </section>

  {/* FAQ */}
  <section class="border-t border-zinc-200 py-12 dark:border-zinc-800">
    <div class="container-wide">
      <h2 class="text-2xl font-bold tracking-tight">FAQ</h2>
      <div class="mt-6 max-w-3xl space-y-3">
        {faq.map((q) => (
          <details class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
            <summary class="cursor-pointer font-medium">{q.question}</summary>
            <p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300">{q.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
