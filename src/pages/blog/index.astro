---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { formatDate } from '../../lib/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.publish_date - +a.data.publish_date
);
---
<Layout
  title="Blog — AI Tools Review"
  description="Long-form guides, model breakdowns, and how-tos for getting more out of today's AI tools."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Blog', href: '/blog' }]}
>
  <div class="container-wide py-10">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Blog', href: '/blog' }]} />
    <header class="mt-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
      <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-400">Guides, breakdowns, and tutorials.</p>
    </header>
    <ul class="mt-8 divide-y divide-zinc-200 dark:divide-zinc-800">
      {posts.map((p) => (
        <li class="flex items-start justify-between gap-6 py-5">
          <div>
            <h2 class="font-semibold"><a href={`/blog/${p.slug}`} class="no-underline hover:underline">{p.data.title}</a></h2>
            <p class="mt-1 line-clamp-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">{p.data.description}</p>
            <p class="mt-2 text-xs text-zinc-500">{p.data.tags.join(' · ')}</p>
          </div>
          <time class="hidden shrink-0 text-sm text-zinc-500 sm:block" datetime={p.data.publish_date.toISOString()}>{formatDate(p.data.publish_date)}</time>
        </li>
      ))}
    </ul>
  </div>
</Layout>
