import ProseLayout from '../layouts/ProseLayout.astro';
---
<ProseLayout
  title="Contact"
  description="Get in touch with the AI Tools Review editor for corrections, tips, or partnership inquiries."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Contact', href: '/contact' }]}
>
  <h1>Contact</h1>
  <p>The best way to reach us is by email. We reply to most messages within 2 business days.</p>
  <ul>
    <li><strong>General / corrections:</strong> hello@example.com</li>
    <li><strong>Tip a tool for review:</strong> tips@example.com</li>
    <li><strong>Partnerships / press:</strong> partnerships@example.com</li>
  </ul>
  <p>We do not publish sponsored reviews. Vendors asking to "collaborate on content" will receive a polite no.</p>
</ProseLayout>
