---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found" description="The page you're looking for doesn't exist." noindex={true}>
  <div class="container-prose py-24 text-center">
    <p class="text-sm font-medium text-brand-700 dark:text-brand-300">404</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">We can't find that page</h1>
    <p class="mt-3 text-zinc-600 dark:text-zinc-400">It may have moved or never existed. Here are some good places to start:</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary">Home</a>
      <a href="/tools" class="btn-secondary">All reviews</a>
      <a href="/best" class="btn-secondary">Best-of lists</a>
    </div>
  </div>
</Layout>
