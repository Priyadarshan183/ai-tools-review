---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
const tools = await getCollection('tools');
const counts = Object.fromEntries(
  categories.map((c) => [c.data.slug, tools.filter((t) => t.data.category.id === c.id).length])
);
---
<Layout
  title="AI tool categories"
  description="Browse AI tools by what they actually do — writing, image, video, code, research, and more."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Categories', href: '/categories' }]}
>
  <div class="container-wide py-10">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Categories', href: '/categories' }]} />
    <header class="mt-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">AI tool categories</h1>
      <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-400">Curated lists by use case. Every tool has been hands-on tested.</p>
    </header>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((c) => (
        <a href={`/categories/${c.data.slug}`} class="card group block p-5 no-underline">
          <div class="text-2xl">{c.data.icon ?? '⚡'}</div>
          <h2 class="mt-2 text-lg font-semibold text-zinc-900 dark:text-zinc-100">{c.data.name}</h2>
          <p class="mt-1 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">{c.data.description}</p>
          <p class="mt-3 text-sm font-medium text-brand-700 group-hover:underline dark:text-brand-300">{counts[c.data.slug] ?? 0} tools →</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
