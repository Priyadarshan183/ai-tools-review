---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { formatDate } from '../../lib/format';

const lists = (await getCollection('best', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.updated_date - +a.data.updated_date
);
---
<Layout
  title="Best AI tools lists"
  description="Curated 'best of' lists for specific use cases — students, marketers, free options, and more."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Best lists', href: '/best' }]}
>
  <div class="container-wide py-10">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Best lists', href: '/best' }]} />
    <header class="mt-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Best-of lists</h1>
      <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-400">Hand-picked recommendations for specific use cases.</p>
    </header>
    <ul class="mt-8 divide-y divide-zinc-200 dark:divide-zinc-800">
      {lists.map((l) => (
        <li class="flex items-center justify-between py-4">
          <div>
            <h2 class="font-semibold"><a href={`/best/${l.slug}`} class="no-underline hover:underline">{l.data.headline}</a></h2>
            <p class="mt-1 line-clamp-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">{l.data.intro}</p>
          </div>
          <time class="hidden shrink-0 text-sm text-zinc-500 sm:block" datetime={l.data.updated_date.toISOString()}>{formatDate(l.data.updated_date)}</time>
        </li>
      ))}
    </ul>
  </div>
</Layout>
