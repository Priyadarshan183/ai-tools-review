---
import '../styles/global.css';
import { SITE } from '../config/site.mjs';
import SEOHead from '../components/SEOHead.astro';
import JsonLd from '../components/JsonLd.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import {
  organizationJsonLd,
  websiteJsonLd,
  breadcrumbJsonLd,
} from '../lib/jsonld';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  breadcrumbs?: { name: string; href: string }[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  publishedTime,
  modifiedTime,
  breadcrumbs,
  jsonLd,
} = Astro.props;

const base: Record<string, unknown>[] = [organizationJsonLd(), websiteJsonLd()];
if (breadcrumbs && breadcrumbs.length > 1) base.push(breadcrumbJsonLd(breadcrumbs));
const extras = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...base, ...extras];
---
<!doctype html>
<html lang={SITE.defaultLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#5b5cf6" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefers)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <script define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
      window.SITE_BASE = (baseUrl || '/').replace(/\/$/, '');
    </script>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />
    <JsonLd data={allJsonLd} />
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-2 focus:top-2 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:shadow dark:focus:bg-zinc-900">Skip to content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
