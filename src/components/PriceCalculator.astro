---
export interface Props { input: number | null; output: number | null; modelName: string; }
const { input, output, modelName } = Astro.props;
const id = `calc-${Math.random().toString(36).slice(2, 8)}`;
---
{(input != null || output != null) && (
  <div class="card p-4" data-calc-root data-input={input ?? ''} data-output={output ?? ''}>
    <div class="text-sm font-semibold">Estimate your cost</div>
    <div class="mt-3 grid gap-3 sm:grid-cols-2">
      <label class="block text-xs text-zinc-500">
        Input tokens
        <input type="number" min="0" step="1000" value="1000000" data-calc="in" class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-2 py-1.5 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
      </label>
      <label class="block text-xs text-zinc-500">
        Output tokens
        <input type="number" min="0" step="1000" value="200000" data-calc="out" class="mt-1 block w-full rounded-md border border-zinc-300 bg-white px-2 py-1.5 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
      </label>
    </div>
    <div class="mt-3 flex items-baseline justify-between border-t border-zinc-200 pt-3 dark:border-zinc-800">
      <span class="text-xs text-zinc-500">Estimated total for {modelName}</span>
      <span class="text-lg font-semibold tabular-nums" data-calc-out>$0.00</span>
    </div>
    <script is:inline>
    (function () {
      const root = document.currentScript.previousElementSibling.parentElement; // not used
    })();
    </script>
  </div>
)}

<script is:inline>
(function () {
  document.querySelectorAll('[data-calc-root]').forEach((root) => {
    const inPrice = parseFloat(root.dataset.input || '0') || 0;
    const outPrice = parseFloat(root.dataset.output || '0') || 0;
    const inIn = root.querySelector('[data-calc="in"]');
    const inOut = root.querySelector('[data-calc="out"]');
    const dest = root.querySelector('[data-calc-out]');
    function update() {
      const i = parseFloat(inIn.value || '0') || 0;
      const o = parseFloat(inOut.value || '0') || 0;
      const cost = (i / 1_000_000) * inPrice + (o / 1_000_000) * outPrice;
      dest.textContent = '$' + cost.toFixed(cost < 1 ? 4 : 2);
    }
    inIn.addEventListener('input', update);
    inOut.addEventListener('input', update);
    update();
  });
})();
</script>
