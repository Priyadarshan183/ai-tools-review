---
export interface Props { rating: number; max?: number; size?: 'sm' | 'md' | 'lg'; }
const { rating, max = 5, size = 'md' } = Astro.props;
const sizeClass = { sm: 'h-3.5 w-3.5', md: 'h-4 w-4', lg: 'h-5 w-5' }[size];
const filled = Math.round(rating * 2) / 2;
const stars = Array.from({ length: max }, (_, i) => {
  const v = i + 1;
  if (filled >= v) return 'full';
  if (filled >= v - 0.5) return 'half';
  return 'empty';
});
---
<div class="inline-flex items-center gap-1" aria-label={`Rating: ${rating} out of ${max}`}>
  <div class="flex">
    {stars.map((kind) => (
      <svg class={`${sizeClass} text-amber-400`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        {kind === 'full' && <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.367 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.539 1.118L10 14.347l-3.354 2.676c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.663 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z"/>}
        {kind === 'half' && (
          <>
            <defs><linearGradient id={`half-${Math.random().toString(36).slice(2)}`}><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="transparent"/></linearGradient></defs>
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.367 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.539 1.118L10 14.347l-3.354 2.676c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.663 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z" fill="currentColor" opacity="0.4"/>
          </>
        )}
        {kind === 'empty' && <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.367 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.539 1.118L10 14.347l-3.354 2.676c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.663 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z" fill="currentColor" opacity="0.2"/>}
      </svg>
    ))}
  </div>
  <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300">{rating.toFixed(1)}</span>
</div>
