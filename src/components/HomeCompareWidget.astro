---
import { MODELS, formatPrice, formatTokens } from '../lib/models';
const options = MODELS
  .filter((m) => m.pricing.input_per_million != null || Object.keys(m.benchmarks).length > 0)
  .map((m) => ({ slug: m.slug, name: m.name, provider: m.provider }))
  .sort((a, b) => a.name.localeCompare(b.name));

// Embed a minimal subset for the client island
const payload = MODELS.map((m) => ({
  slug: m.slug,
  name: m.name,
  provider: m.provider,
  context_window: m.context_window,
  max_output_tokens: m.max_output_tokens,
  modality: m.modality,
  is_open_weight: m.is_open_weight,
  pricing: m.pricing,
  benchmarks: Object.fromEntries(
    Object.entries(m.benchmarks).map(([k, v]) => [k, v.score])
  ),
}));
---
<section aria-label="Side-by-side comparison" class="container-wide">
  <div class="card p-5">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="text-xl font-semibold">Compare two models</h2>
      <a href="/leaderboard" class="text-sm text-brand-700 hover:underline dark:text-brand-300">Full leaderboard →</a>
    </div>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <label class="block text-xs font-medium text-zinc-500">
        Model A
        <select data-compare="a" class="mt-1 block w-full rounded-md border border-zinc-300 bg-white p-2 text-sm dark:border-zinc-700 dark:bg-zinc-900">
          {options.map((o) => <option value={o.slug}>{o.name} ({o.provider})</option>)}
        </select>
      </label>
      <label class="block text-xs font-medium text-zinc-500">
        Model B
        <select data-compare="b" class="mt-1 block w-full rounded-md border border-zinc-300 bg-white p-2 text-sm dark:border-zinc-700 dark:bg-zinc-900">
          {options.map((o) => <option value={o.slug}>{o.name} ({o.provider})</option>)}
        </select>
      </label>
    </div>
    <div data-compare-result class="mt-4 hidden text-sm">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-zinc-200 text-left dark:border-zinc-800">
              <th class="py-2 pr-4 font-medium text-zinc-500"></th>
              <th class="py-2 pr-4 font-semibold" data-compare-name="a"></th>
              <th class="py-2 font-semibold" data-compare-name="b"></th>
            </tr>
          </thead>
          <tbody data-compare-rows></tbody>
        </table>
      </div>
      <div class="mt-3 flex gap-3 text-sm">
        <a data-compare-link class="font-medium text-brand-700 hover:underline dark:text-brand-300">Open full comparison →</a>
      </div>
    </div>
    <p data-compare-empty class="mt-4 text-sm text-zinc-500">Pick two models to see a side-by-side diff.</p>
  </div>
</section>

<script type="application/json" id="compare-data" set:html={JSON.stringify(payload)}></script>
<script is:inline>
(function () {
  const dataEl = document.getElementById('compare-data');
  if (!dataEl) return;
  const data = JSON.parse(dataEl.textContent || '[]');
  const bySlug = Object.fromEntries(data.map((m) => [m.slug, m]));
  const selA = document.querySelector('select[data-compare="a"]');
  const selB = document.querySelector('select[data-compare="b"]');
  const result = document.querySelector('[data-compare-result]');
  const empty = document.querySelector('[data-compare-empty]');
  const nameA = document.querySelector('[data-compare-name="a"]');
  const nameB = document.querySelector('[data-compare-name="b"]');
  const rows = document.querySelector('[data-compare-rows]');
  const link = document.querySelector('[data-compare-link]');
  if (!selA || !selB || !result || !empty || !rows) return;

  const fmtPrice = (n) => (n == null ? '—' : n === 0 ? 'Free' : '$' + n.toFixed(n < 1 ? 3 : 2));
  const fmtToks = (n) => (n == null ? '—' : n >= 1e6 ? (n / 1e6).toFixed(1) + 'M' : n >= 1e3 ? (n / 1e3).toFixed(0) + 'K' : String(n));
  const fmtScore = (n) => (n == null ? '—' : n.toFixed(1));

  const benches = ['gpqa_diamond', 'swe_bench_verified', 'swe_bench_pro', 'humanitys_last_exam', 'terminal_bench_2', 'aime_2025', 'arena_elo'];
  const benchLabels = {
    gpqa_diamond: 'GPQA Diamond',
    swe_bench_verified: 'SWE-Bench Verified',
    swe_bench_pro: 'SWE-Bench Pro',
    humanitys_last_exam: 'Humanity’s Last Exam',
    terminal_bench_2: 'Terminal-Bench 2',
    aime_2025: 'AIME 2025',
    arena_elo: 'Arena Elo',
  };

  function compareSlug(a, b) {
    return [a, b].sort().join('-vs-');
  }

  function render() {
    const a = bySlug[selA.value];
    const b = bySlug[selB.value];
    if (!a || !b || a.slug === b.slug) {
      result.classList.add('hidden');
      empty.classList.remove('hidden');
      empty.textContent = a && b && a.slug === b.slug ? 'Pick two different models.' : 'Pick two models to see a side-by-side diff.';
      return;
    }
    empty.classList.add('hidden');
    result.classList.remove('hidden');
    nameA.textContent = a.name;
    nameB.textContent = b.name;

    const rowsHtml = [];
    const row = (label, va, vb) => `<tr class="border-b border-zinc-100 dark:border-zinc-900"><td class="py-2 pr-4 text-zinc-500">${label}</td><td class="py-2 pr-4">${va}</td><td class="py-2">${vb}</td></tr>`;
    rowsHtml.push(row('Provider', a.provider, b.provider));
    rowsHtml.push(row('Open weight', a.is_open_weight ? 'Yes' : 'No', b.is_open_weight ? 'Yes' : 'No'));
    rowsHtml.push(row('Context window', fmtToks(a.context_window), fmtToks(b.context_window)));
    rowsHtml.push(row('Max output', fmtToks(a.max_output_tokens), fmtToks(b.max_output_tokens)));
    rowsHtml.push(row('Modality', (a.modality || []).join(', ') || '—', (b.modality || []).join(', ') || '—'));
    rowsHtml.push(row('Input $/M', fmtPrice(a.pricing.input_per_million), fmtPrice(b.pricing.input_per_million)));
    rowsHtml.push(row('Output $/M', fmtPrice(a.pricing.output_per_million), fmtPrice(b.pricing.output_per_million)));
    rowsHtml.push(row('Free tier', a.pricing.has_free_tier ? 'Yes' : 'No', b.pricing.has_free_tier ? 'Yes' : 'No'));
    for (const k of benches) {
      const va = a.benchmarks?.[k];
      const vb = b.benchmarks?.[k];
      if (va == null && vb == null) continue;
      rowsHtml.push(row(benchLabels[k] || k, fmtScore(va), fmtScore(vb)));
    }
    rows.innerHTML = rowsHtml.join('');
    if (link) link.setAttribute('href', (window.SITE_BASE || '') + '/compare/' + compareSlug(a.slug, b.slug));
  }

  selA.addEventListener('change', render);
  selB.addEventListener('change', render);
  // Sensible defaults
  if (data.length >= 2) {
    selA.value = data[0].slug;
    selB.value = data.find((m) => m.slug !== data[0].slug)?.slug || data[1].slug;
    render();
  }
})();
</script>
